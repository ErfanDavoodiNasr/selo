{
  "name": "selo/messenger",
  "description": "SELO shared-hosting PHP messenger",
  "license": "proprietary",
  "type": "project",
  "require": {
    "php": ">=8.2 <8.3",
    "laravel/framework": "^8.83"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "config": {
    "audit": {
      "block-insecure": false
    },
    "optimize-autoloader": true,
    "sort-packages": true,
    "platform": {
      "php": "8.2.29"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
